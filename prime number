#!/bin/bash

read -p "Enter a number: " num

# Numbers less than 2 are not prime
if [ $num -lt 2 ]; then
    echo "$num is not a prime number."
    exit
fi

# Logic: Check for divisors from 2 up to num/2
for ((i=2; i<=$num/2; i++))
do
    if [ $((num % i)) -eq 0 ]; then
        echo "$num is not a prime number."
        exit
    fi
done

echo "$num is a prime number."
